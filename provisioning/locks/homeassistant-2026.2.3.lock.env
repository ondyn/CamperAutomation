LOCK_HA_VERSION="2026.2.3"
LOCK_HA_REQUIRES_PYTHON=">=3.13.2"
LOCK_HA_SOURCE_URL="https://github.com/home-assistant/core/archive/refs/tags/2026.2.3.tar.gz"
LOCK_HA_SOURCE_SHA256="af6b5c9143e76e08f9af78ac8c7a613ef6301970d467c50365e36f4aaef1b9a8"
LOCK_HA_SOURCE_DIR="core-2026.2.3"
LOCK_HA_INSTALL_TOOL="uv"

# Extra Python packages needed to satisfy Home Assistant's default runtime on
# current Termux/Android, where some components are not covered by the base
# release requirements path alone.
# Note: typing-extensions is installed separately to satisfy multiple HA deps
# (homeassistant, pydantic, sqlalchemy etc.) that are not covered by system
# site-packages in uv pip check context.
LOCK_HA_RUNTIME_PIP_PACKAGES=(
  "PyNaCl==1.6.2"
  "home-assistant-frontend==20260128.6"
  # Keep orjson on a stable Rust-compatible build for Termux/Android.
  "orjson==3.11.5"
  "go2rtc-client==0.4.0"
  "aiodhcpwatcher==1.2.1"
  "av==16.0.1"
  "pyatv==0.17.0"
  # HA built-in component deps missing from requirements.txt on --skip-pip
  "typing-extensions>=4.15.0,<5.0"
  "aiodiscover==2.7.1"
  "aiousbwatcher==1.1.1"
  "pyserial==3.5"
  "async-upnp-client==0.46.2"
)

# Exact Termux package versions currently installed on the target device.
# Reproducibility depends on these versions remaining available in the selected mirror.
LOCK_TERMUX_PACKAGES=(
  "ca-certificates=1:2026.03.19"
  "curl=8.20.0"
  "python=3.13.13-1"
  "python-psutil=7.2.2"
  "python-grpcio=1.80.0"
  "binutils=2.46.0-3"
  "clang=21.1.8-2"
  "libsodium=1.0.22-1"
  "cmake=4.3.2-1"
  "ffmpeg=8.1.1"
  "make=4.4.1-1"
  "pkg-config=0.29.2-3"
  "rust=1.95.0"
  "uv=0.11.8"
  "openssh=10.3p1-1"
  "screen=5.0.1-1"
  "termux-tools=1.46.0+really1.45.0-1"
)
