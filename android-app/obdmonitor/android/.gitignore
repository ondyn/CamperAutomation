# Gradle build cache – generated on every build, machine-specific
.gradle/
/captures/

# Build outputs
/build/
.cxx/

# Android Studio / IDE
*.iml

# Gradle wrapper binaries – regenerated by `flutter build`, not needed in VCS
gradlew
gradlew.bat

# Machine-specific SDK/NDK paths (set by the local Flutter toolchain)
local.properties

# Generated plugin registration – created by `flutter pub get`
GeneratedPluginRegistrant.java

# Signing config – never commit keys
key.properties
**/*.keystore
**/*.jks
